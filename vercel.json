{
  "framework": null,
  "installCommand": "cd backend && npm ci && cd ../frontend && npm ci",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
